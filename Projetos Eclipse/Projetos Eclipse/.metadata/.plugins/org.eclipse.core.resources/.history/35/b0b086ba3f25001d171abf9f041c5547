import java.util.Scanner;

public class Aula3 {

	public static void main(String[] args) {
		
		Scanner entrada = new Scanner(System.in);
		
		final int tam = 10;
		
		int[] vet=new int[tam];
		
			for(int x=0;x<tam;x++) {
				System.out.print("Digite a idade do "+(x+1)+"º membro da sua familia");
				System.out.print("um de cada vez :");
				
				vet[x] = entrada.nextInt();				
			}
			int soma=0;
			for(int x=0;x<tam;x++) {
				System.out.print(vet[x]+"|");
				soma=soma+vet[x];
			}
		System.out.println("A soma das idades deu: "+soma);
		
		entrada.close();
	}
}
