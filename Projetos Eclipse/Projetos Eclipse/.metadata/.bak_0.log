			System.out.println(inic+"º: "+base+" X "+inic+" = "+(base*inic));
			
		if (inic<fim) {
			for ((inic<=fim); inic++);
			System.out.println(inic+"º: "+base+" X "+inic+" = "+(base*inic));
		}
		
		
